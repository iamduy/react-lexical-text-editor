{
  "name": "react-lexical-text-editor",
  "version": "1.0.12",
  "type": "module",
  "description": "A rich text editor based on Lexical with images, tables, links, etc.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "typecheck": "npx tsc --noEmit --project tsconfig.json && npx tsc --noEmit --project tsconfig.dev.json",
    "check": "npm run typecheck && npm run build && npm run build:playground",
    "build": "npm run build:lib",
    "build:lib": "rollup -c --bundleConfigAsCjs",
    "build:playground": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "keywords": [
    "lexical",
    "rich-text",
    "editor",
    "react",
    "text-editor",
    "lexical-editor",
    "lexical-react",
    "react-lexical",
    "lexical-text-editor"
  ],
  "author": "SanMario",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamduy/react-lexical-text-editor.git"
  },
  "homepage": "https://deepwiki.com/iamduy/react-lexical-text-editor",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rollup/plugin-url": "^8.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "postcss-import": "^16.1.1",
    "postcss-url": "^10.1.3",
    "prettier": "^3.6.2",
    "rollup": "^4.18.1",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.6.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@lexical/clipboard": "^0.39.0",
    "@lexical/code": "^0.39.0",
    "@lexical/hashtag": "^0.39.0",
    "@lexical/html": "^0.39.0",
    "@lexical/link": "^0.39.0",
    "@lexical/list": "^0.39.0",
    "@lexical/mark": "^0.39.0",
    "@lexical/overflow": "^0.39.0",
    "@lexical/react": "^0.39.0",
    "@lexical/rich-text": "^0.39.0",
    "@lexical/selection": "^0.39.0",
    "@lexical/table": "^0.39.0",
    "@lexical/utils": "^0.39.0",
    "@lexical/yjs": "^0.39.0",
    "lexical": "^0.39.0",
    "yjs": "^13.6.28"
  }
}
